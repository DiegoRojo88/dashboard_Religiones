<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Proyecto — Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #fafaf9;
      color: #1a1a1a;
      font-family: 'Inter', sans-serif;
      font-weight: 300;
      min-height: 100vh;
    }

    main {
      max-width: 960px;
      margin: 0 auto;
      padding: 80px 32px 64px;
    }

    /* ── HEADER ── */
    .meta {
      font-size: 11px;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: #aaa;
      margin-bottom: 20px;
    }

    h1 {
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 400;
      letter-spacing: -.02em;
      color: #111;
      margin-bottom: 12px;
      line-height: 1.15;
    }

    .desc {
      font-size: 15px;
      color: #777;
      line-height: 1.7;
      max-width: 480px;
      margin-bottom: 48px;
    }

    /* ── TEAM ── */
    .team-label {
      font-size: 11px;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: #aaa;
      margin-bottom: 14px;
    }

    .team {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 56px;
    }

    .member {
      font-size: 13px;
      color: #444;
      background: #f0efed;
      padding: 5px 14px;
      border-radius: 100px;
    }

    /* ── DIVIDER ── */
    hr {
      border: none;
      border-top: 1px solid #e8e8e6;
      margin-bottom: 40px;
    }

    /* ── DASHBOARD ── */
    .dash-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
      flex-wrap: wrap;
      gap: 10px;
    }

    .dash-label {
      font-size: 13px;
      color: #888;
    }

    .open-btn {
      font-size: 12px;
      color: #555;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      border: 1px solid #ddd;
      border-radius: 100px;
      transition: border-color .2s, color .2s;
    }
    .open-btn:hover { border-color: #aaa; color: #111; }
    .open-btn svg { width: 12px; height: 12px; }

    .iframe-wrap {
      border: 1px solid #e4e4e2;
      border-radius: 10px;
      overflow: hidden;
      background: #fff;
    }

    iframe {
      display: block;
      width: 100%;
      height: 580px;
      border: none;
    }

    /* ── FOOTER ── */
    footer {
      margin-top: 48px;
      padding-top: 24px;
      border-top: 1px solid #e8e8e6;
      font-size: 12px;
      color: #bbb;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px;
    }

    @media (max-width: 600px) {
      main { padding: 48px 20px 48px; }
      iframe { height: 380px; }
    }
  </style>
</head>
<body>
<main>

  <!-- HEADER -->
  <p class="meta">Tecnológico de Monterrey · 2026</p>
  <h1>Proyecto</h1>
  <p class="desc">
    Visualización interactiva de los datos del proyecto. Explora los indicadores clave directamente desde el dashboard.
  </p>

  <!-- EQUIPO -->
  <p class="team-label">Equipo</p>
  <div class="team">
    <!-- Cambia los nombres aquí -->
    <span class="member">Miembro 1</span>
    <span class="member">Miembro 2</span>
    <span class="member">Miembro 3</span>
    <span class="member">Miembro 4</span>
  </div>

  <hr/>

  <!-- DASHBOARD -->
  <div class="dash-header">
    <span class="dash-label">Dashboard interactivo</span>
    <a class="open-btn"
       href="https://app.powerbi.com/view?r=eyJrIjoiY2VjNDgwMmEtZGE4OS00M2MxLTk2NjItYWI5ZjgzMjY1ODVhIiwidCI6ImM2NWEzZWE2LTBmN2MtNDAwYi04OTM0LTVhNmRjMTcwNTY0NSIsImMiOjR9"
       target="_blank" rel="noopener">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M7 2H2v12h12V9M9 2h5v5M14 2L8 8"/>
      </svg>
      Abrir en Power BI
    </a>
  </div>

  <div class="iframe-wrap">
    <iframe
      title="Dashboard Proyecto"
      src="https://app.powerbi.com/view?r=eyJrIjoiY2VjNDgwMmEtZGE4OS00M2MxLTk2NjItYWI5ZjgzMjY1ODVhIiwidCI6ImM2NWEzZWE2LTBmN2MtNDAwYi04OTM0LTVhNmRjMTcwNTY0NSIsImMiOjR9"
      allowFullScreen="true">
    </iframe>
  </div>

  <!-- FOOTER -->
  <footer>
    <span>Campus Querétaro</span>
    <span>Enero – Junio 2026</span>
  </footer>

</main>
</body>
</html>
